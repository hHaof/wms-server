PORT=5000
NODE_ENV=development

# MongoDB Atlas URI — get from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/wms?retryWrites=true&w=majority

# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_ACCESS_EXPIRES=15m

JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_REFRESH_EXPIRES=7d

# Optional — set to your Netlify/Vercel URL when calling API from a different origin
# CORS_ORIGIN=https://your-app.netlify.app
